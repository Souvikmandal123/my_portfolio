# Copy this file to .env in the same folder (backend/.env) and fill in real values.
# Never commit .env to git.

# Inbox where contact form submissions are delivered
CONTACT_TO_EMAIL=you@example.com

# Shown as the sender (use an address your SMTP allows, often same as EMAIL_HOST_USER)
DEFAULT_FROM_EMAIL=Portfolio <you@example.com>

# SMTP — Gmail example (use an App Password if 2FA is on: Google Account → Security → App passwords)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=true
EMAIL_USE_SSL=false

EMAIL_HOST_USER=you@gmail.com
EMAIL_HOST_PASSWORD=your-app-password-here
